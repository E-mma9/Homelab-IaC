# ── Terraform ──────────────────────────────
# Provider plugins and modules (large, machine-specific)
**/.terraform/*

# State files — can contain secrets, never commit
*.tfstate
*.tfstate.*

# Variable files — contain credentials, never commit
*.tfvars
*.tfvars.json

# Crash logs and overrides
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraform.tfstate.lock.info
.terraformrc
terraform.rc

# ── Ansible ────────────────────────────────
*.retry
*vault-password*
*.vault

# ── Secrets / credentials (belt-and-suspenders) ──
*.pem
*.key
.env
*.env
*secret*

# ── Editor / OS noise ──────────────────────
.vscode/
.idea/
*.swp
*~
.DS_Store